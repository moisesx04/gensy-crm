# Vercel Postgres Environment Variables
# These are automatically provided by Vercel when you connect a Postgres Storage.
# You can also copy them from the Vercel Dashboard for local development.

POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# App Security — REQUIRED. Generate a strong random string (e.g. openssl rand -base64 32)
JWT_SECRET=

# Init Endpoint Protection — REQUIRED to call /api/init
# Set this to a secret value and include it as x-init-secret header when calling /api/init
INIT_SECRET=

# First Admin Seed — Used by /api/init to create the initial admin user (only if no users exist)
ADMIN_SEED_EMAIL=
ADMIN_SEED_PASSWORD=
